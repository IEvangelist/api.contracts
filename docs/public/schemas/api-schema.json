{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ievangelist.github.io/api.contracts/schemas/api-schema.json",
  "title": "API Contracts Assembly Schema",
  "description": "Defines the shape of *.api-schema.json files emitted by the ApiContracts.Generator Roslyn source generator. Each file is a deterministic, self-describing snapshot of a .NET assembly's public API surface.",
  "type": "object",
  "required": ["$schema", "schemaVersion", "package", "apiHash", "types"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Reference to this JSON Schema definition.",
      "const": "https://ievangelist.github.io/api.contracts/schemas/api-schema.json"
    },
    "schemaVersion": {
      "type": "string",
      "description": "Version of the schema format (semver).",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "package": {
      "$ref": "#/$defs/package"
    },
    "apiHash": {
      "type": "string",
      "description": "Deterministic SHA-256 hash of the canonical API model in the format sha256:<hex>.",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "signature": {
      "$ref": "#/$defs/signature"
    },
    "types": {
      "type": "array",
      "description": "All public types in the assembly, sorted by namespace then name.",
      "items": {
        "$ref": "#/$defs/type"
      }
    }
  },
  "$defs": {
    "package": {
      "type": "object",
      "description": "Assembly/package metadata.",
      "required": ["name", "version", "targetFramework"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Assembly name."
        },
        "version": {
          "type": "string",
          "description": "Assembly version."
        },
        "targetFramework": {
          "type": "string",
          "description": "Target framework moniker (e.g. net10.0)."
        }
      }
    },
    "signature": {
      "type": "object",
      "description": "Optional RSA-SHA256 cryptographic signature envelope.",
      "required": ["algorithm", "publicKeyId", "value"],
      "additionalProperties": false,
      "properties": {
        "algorithm": {
          "type": "string",
          "const": "RSA-SHA256"
        },
        "publicKeyId": {
          "type": "string",
          "description": "Identifier for the public key used to verify the signature."
        },
        "value": {
          "type": "string",
          "description": "Base64-encoded signature of the canonical JSON."
        }
      }
    },
    "type": {
      "type": "object",
      "description": "A public type in the assembly.",
      "required": ["name", "fullName", "namespace", "kind", "accessibility", "members"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Simple type name."
        },
        "fullName": {
          "type": "string",
          "description": "Fully qualified type name including namespace."
        },
        "namespace": {
          "type": "string",
          "description": "Containing namespace."
        },
        "kind": {
          "type": "string",
          "description": "Type kind.",
          "enum": ["class", "struct", "record", "record struct", "interface", "enum", "delegate"]
        },
        "accessibility": {
          "type": "string",
          "description": "Declared accessibility.",
          "enum": ["public", "internal"]
        },
        "isAbstract": {
          "type": "boolean",
          "description": "True if the type is abstract."
        },
        "isSealed": {
          "type": "boolean",
          "description": "True if the type is sealed."
        },
        "isStatic": {
          "type": "boolean",
          "description": "True if the type is static."
        },
        "isGeneric": {
          "type": "boolean",
          "description": "True if the type has generic type parameters."
        },
        "genericParameters": {
          "type": "array",
          "description": "Generic type parameters with optional constraints.",
          "items": {
            "$ref": "#/$defs/genericParameter"
          }
        },
        "baseType": {
          "type": "string",
          "description": "Fully qualified base type name (omitted for System.Object)."
        },
        "interfaces": {
          "type": "array",
          "description": "Implemented interfaces, sorted alphabetically.",
          "items": {
            "type": "string"
          }
        },
        "docs": {
          "$ref": "#/$defs/docs"
        },
        "enumMembers": {
          "type": "array",
          "description": "Members of an enum type.",
          "items": {
            "$ref": "#/$defs/enumMember"
          }
        },
        "members": {
          "type": "array",
          "description": "Public members sorted by kind then name.",
          "items": {
            "$ref": "#/$defs/member"
          }
        },
        "attributes": {
          "type": "array",
          "description": "Shape-affecting attributes applied to this type.",
          "items": {
            "$ref": "#/$defs/attribute"
          }
        }
      }
    },
    "member": {
      "type": "object",
      "description": "A public member of a type.",
      "required": ["name", "kind", "accessibility", "signature"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Member name (.ctor for constructors, this[] for indexers)."
        },
        "kind": {
          "type": "string",
          "description": "Member kind.",
          "enum": ["constructor", "method", "property", "field", "event", "indexer"]
        },
        "accessibility": {
          "type": "string",
          "description": "Declared accessibility of the member.",
          "enum": ["public", "protected", "internal", "protected internal", "private protected"]
        },
        "signature": {
          "type": "string",
          "description": "Minimally qualified member signature."
        },
        "returnType": {
          "type": "string",
          "description": "Fully qualified return type."
        },
        "isReturnNullable": {
          "type": "boolean",
          "description": "True if the return type is nullable."
        },
        "isStatic": {
          "type": "boolean"
        },
        "isAbstract": {
          "type": "boolean"
        },
        "isVirtual": {
          "type": "boolean"
        },
        "isOverride": {
          "type": "boolean"
        },
        "isAsync": {
          "type": "boolean"
        },
        "parameters": {
          "type": "array",
          "description": "Method/indexer parameters.",
          "items": {
            "$ref": "#/$defs/parameter"
          }
        },
        "attributes": {
          "type": "array",
          "description": "Shape-affecting attributes applied to this member.",
          "items": {
            "$ref": "#/$defs/attribute"
          }
        },
        "docs": {
          "$ref": "#/$defs/docs"
        }
      }
    },
    "parameter": {
      "type": "object",
      "description": "A method or indexer parameter.",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "description": "Fully qualified parameter type."
        },
        "isNullable": {
          "type": "boolean"
        },
        "isOptional": {
          "type": "boolean"
        },
        "defaultValue": {
          "type": "string",
          "description": "String representation of the default value."
        },
        "modifier": {
          "type": "string",
          "description": "Parameter modifier.",
          "enum": ["ref", "out", "in", "ref readonly", "params"]
        }
      }
    },
    "genericParameter": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "enumMember": {
      "type": "object",
      "required": ["name", "value"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "value": {
          "type": "integer"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "docs": {
      "type": "object",
      "description": "Rich structured XML documentation preserving inline references, code, lists, and exceptions.",
      "additionalProperties": false,
      "properties": {
        "summary": {
          "$ref": "#/$defs/docContent",
          "description": "Summary documentation content."
        },
        "remarks": {
          "$ref": "#/$defs/docContent",
          "description": "Detailed remarks documentation content."
        },
        "returns": {
          "$ref": "#/$defs/docContent",
          "description": "Return value documentation content."
        },
        "value": {
          "$ref": "#/$defs/docContent",
          "description": "Property value documentation content."
        },
        "parameters": {
          "type": "object",
          "description": "Parameter name to rich description mapping.",
          "additionalProperties": {
            "$ref": "#/$defs/docContent"
          }
        },
        "typeParameters": {
          "type": "object",
          "description": "Type parameter name to rich description mapping.",
          "additionalProperties": {
            "$ref": "#/$defs/docContent"
          }
        },
        "exceptions": {
          "type": "array",
          "description": "Exceptions that may be thrown.",
          "items": {
            "$ref": "#/$defs/docException"
          }
        },
        "permissions": {
          "type": "array",
          "description": "Required permissions.",
          "items": {
            "$ref": "#/$defs/docPermission"
          }
        },
        "examples": {
          "type": "array",
          "description": "Code examples.",
          "items": {
            "$ref": "#/$defs/docExample"
          }
        },
        "seeAlso": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "docContent": {
      "type": "array",
      "description": "Rich documentation content as an array of inline nodes.",
      "items": {
        "$ref": "#/$defs/docNode"
      }
    },
    "docNode": {
      "type": "object",
      "description": "A single node in a documentation content tree.",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "description": "Node kind.",
          "enum": ["text", "code", "codeblock", "cref", "href", "langword", "paramref", "typeparamref", "para", "list", "note"]
        },
        "text": {
          "type": "string",
          "description": "Text content for text/code/codeblock kinds, or display text for href kind."
        },
        "value": {
          "type": "string",
          "description": "Reference value: cref doc-ID, href URL, langword keyword, parameter name, or note type."
        },
        "language": {
          "type": "string",
          "description": "Programming language for 'codeblock' kind."
        },
        "children": {
          "$ref": "#/$defs/docContent",
          "description": "Child nodes for para/note kinds."
        },
        "style": {
          "type": "string",
          "description": "List style for 'list' kind.",
          "enum": ["bullet", "number", "table"]
        },
        "header": {
          "$ref": "#/$defs/docListItem",
          "description": "Optional header row for 'list' kind with table style."
        },
        "items": {
          "type": "array",
          "description": "List items for 'list' kind.",
          "items": {
            "$ref": "#/$defs/docListItem"
          }
        }
      }
    },
    "docListItem": {
      "type": "object",
      "description": "An item in a documentation list.",
      "additionalProperties": false,
      "properties": {
        "term": {
          "$ref": "#/$defs/docContent",
          "description": "Optional term for definition lists."
        },
        "description": {
          "$ref": "#/$defs/docContent",
          "description": "Item description."
        }
      }
    },
    "docException": {
      "type": "object",
      "description": "A documented exception.",
      "required": ["type", "description"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "description": "Exception type doc-ID reference."
        },
        "description": {
          "$ref": "#/$defs/docContent",
          "description": "When the exception is thrown."
        }
      }
    },
    "docPermission": {
      "type": "object",
      "description": "A documented permission requirement.",
      "required": ["type", "description"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "description": "Permission type doc-ID reference."
        },
        "description": {
          "$ref": "#/$defs/docContent",
          "description": "Description of the permission requirement."
        }
      }
    },
    "docExample": {
      "type": "object",
      "description": "A code example.",
      "required": ["language", "code"],
      "additionalProperties": false,
      "properties": {
        "language": {
          "type": "string",
          "description": "Programming language."
        },
        "region": {
          "type": "string",
          "description": "Optional named region."
        },
        "code": {
          "type": "string",
          "description": "The code content."
        },
        "description": {
          "$ref": "#/$defs/docContent",
          "description": "Optional description of the example."
        }
      }
    },
    "attribute": {
      "type": "object",
      "description": "A shape-affecting attribute applied to a type or member.",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Attribute type name."
        },
        "arguments": {
          "type": "object",
          "description": "Named arguments of the attribute.",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    }
  }
}
