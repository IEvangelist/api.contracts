---
/**
 * MemberList — renders all members of a type, grouped by kind.
 *
 * Each kind group is a top-level <h2> section for clean navigation.
 * No letter icons — uses clean headings and count badges.
 */
import MemberCard from './MemberCard.astro';
import AnchorHeading from './AnchorHeading.astro';
import { groupMembersByKind, memberKindLabels } from '../utils/packages';

interface Props {
  members: any[];
  allTypes?: any[];
  packageName?: string;
}

const { members = [], allTypes = [], packageName = '' } = Astro.props;
const groups = groupMembersByKind(members);
---

{groups.size > 0 && (
  <div class="ml">
    {[...groups.entries()].map(([kind, items]) => (
      <section class="ml-group">
        <AnchorHeading id={`members-${kind}`} text={memberKindLabels[kind] ?? kind}>
          <span class="ml-count">{items.length}</span>
        </AnchorHeading>
        <div class="ml-cards">
          {items.map((m: any) => (
            <MemberCard
              member={m}
              allTypes={allTypes}
              packageName={packageName}
            />
          ))}
        </div>
      </section>
    ))}
  </div>
)}

<style>
  .ml {
    margin: 0.5rem 0;
  }
  .ml-group {
    margin-bottom: 2.5rem;
  }
  .ml-group:last-child {
    margin-bottom: 1rem;
  }
  .ml-group-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--sl-color-gray-5);
    color: var(--sl-color-text);
  }
  .ml-group :global(.anchor-heading) {
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--sl-color-gray-5);
  }
  .ml-group :global(.anchor-heading h2) {
    font-size: 1.25rem;
  }
  .ml-group :global(.ml-count) {
    font-size: 0.55em;
    font-weight: 600;
    background: var(--sl-color-gray-5);
    color: var(--sl-color-gray-2);
    padding: 0.1em 0.5em;
    border-radius: 2rem;
    line-height: 1;
    vertical-align: middle;
    display: inline-block;
    margin-inline-start: 0.25em;
  }
  .ml-cards {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
</style>
