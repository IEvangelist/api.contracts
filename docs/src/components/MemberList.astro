---
/**
 * MemberList — renders all members of a type, grouped by kind, using
 * MemberCard for each member.
 */
import MemberCard from './MemberCard.astro';
import { groupMembersByKind, memberKindLabels, memberKindIcons } from '../utils/packages';

interface Props {
  members: any[];
  allTypes?: any[];
  packageName?: string;
}

const { members = [], allTypes = [], packageName = '' } = Astro.props;
const groups = groupMembersByKind(members);
---

{groups.size > 0 && (
  <div class="ml">
    {[...groups.entries()].map(([kind, items]) => (
      <section class="ml-group" id={`members-${kind}`}>
        <h3 class="ml-group-title">
          <span class="ml-kind-icon">{memberKindIcons[kind] ?? '•'}</span>
          {memberKindLabels[kind] ?? kind}
          <span class="ml-count">{items.length}</span>
        </h3>
        <div class="ml-cards">
          {items.map((m: any) => (
            <MemberCard
              member={m}
              allTypes={allTypes}
              packageName={packageName}
            />
          ))}
        </div>
      </section>
    ))}
  </div>
)}

<style>
  .ml {
    margin: 1rem 0;
  }
  .ml-group {
    margin-bottom: 2rem;
  }
  .ml-group-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.35rem;
    border-bottom: 2px solid var(--sl-color-gray-5);
    color: var(--sl-color-white);
  }
  .ml-kind-icon {
    font-size: 1.15rem;
  }
  .ml-count {
    font-size: 0.75rem;
    font-weight: 400;
    background: var(--sl-color-gray-5);
    padding: 0.1rem 0.4rem;
    border-radius: 1rem;
    color: var(--sl-color-gray-2);
  }
  .ml-cards {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
</style>
