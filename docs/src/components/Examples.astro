---
/**
 * Examples component - Renders polyglot code examples with language tabs.
 *
 * @prop {Array} examples - Array of code example objects from the assembly schema
 */
const { examples = [] } = Astro.props;

if (!examples || examples.length === 0) return;

// Group examples by language
const byLang = examples.reduce((acc: Record<string, any[]>, ex: any) => {
  const lang = ex.language ?? 'csharp';
  if (!acc[lang]) acc[lang] = [];
  acc[lang].push(ex);
  return acc;
}, {} as Record<string, any[]>);

const languages = Object.keys(byLang);
const langLabels: Record<string, string> = {
  csharp: 'C#',
  typescript: 'TypeScript',
  python: 'Python',
  java: 'Java',
  go: 'Go',
  rust: 'Rust',
  json: 'JSON',
  xml: 'XML',
  bash: 'Bash',
};
---

<div class="examples-container">
  <div class="tabs" role="tablist">
    {languages.map((lang, i) => (
      <button
        role="tab"
        class={`tab ${i === 0 ? 'active' : ''}`}
        data-lang={lang}
        aria-selected={i === 0 ? 'true' : 'false'}
      >
        {langLabels[lang] ?? lang}
      </button>
    ))}
  </div>
  <div class="tab-panels">
    {languages.map((lang, i) => (
      <div
        class={`tab-panel ${i === 0 ? 'active' : ''}`}
        data-lang={lang}
        role="tabpanel"
      >
        {byLang[lang].map((ex: any) => (
          <div class="example">
            {ex.description && <p class="example-desc">{ex.description}</p>}
            {ex.region && <span class="region-badge">#{ex.region}</span>}
            <div class="code-block">
              <button class="copy-btn" data-code={ex.code} title="Copy code">📋</button>
              <pre><code class={`language-${lang}`}>{ex.code}</code></pre>
            </div>
          </div>
        ))}
      </div>
    ))}
  </div>
</div>

<script>
  document.querySelectorAll('.examples-container').forEach(container => {
    const tabs = container.querySelectorAll('.tab');
    const panels = container.querySelectorAll('.tab-panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const lang = (tab as HTMLElement).dataset.lang;
        tabs.forEach(t => {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
        });
        panels.forEach(p => p.classList.remove('active'));
        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');
        container.querySelector(`.tab-panel[data-lang="${lang}"]`)?.classList.add('active');
      });
    });

    container.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const code = (btn as HTMLElement).dataset.code ?? '';
        navigator.clipboard.writeText(code);
        const original = btn.textContent;
        btn.textContent = '✅';
        setTimeout(() => { btn.textContent = original; }, 1500);
      });
    });
  });
</script>

<style>
  .examples-container {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    overflow: hidden;
    margin: 1rem 0;
  }
  .tabs {
    display: flex;
    background: var(--sl-color-gray-6);
    border-bottom: 1px solid var(--sl-color-gray-5);
    overflow-x: auto;
  }
  .tab {
    padding: 0.5rem 1rem;
    border: none;
    background: none;
    cursor: pointer;
    font-size: 0.875rem;
    color: var(--sl-color-gray-2);
    border-bottom: 2px solid transparent;
    white-space: nowrap;
  }
  .tab:hover {
    background: var(--sl-color-gray-5);
  }
  .tab.active {
    color: var(--sl-color-accent);
    border-bottom-color: var(--sl-color-accent);
    font-weight: 600;
  }
  .tab-panel {
    display: none;
    padding: 0.5rem;
  }
  .tab-panel.active {
    display: block;
  }
  .example {
    margin-bottom: 0.5rem;
  }
  .example-desc {
    font-size: 0.875rem;
    color: var(--sl-color-gray-2);
    margin: 0.25rem 0;
  }
  .region-badge {
    font-size: 0.75rem;
    background: var(--sl-color-gray-5);
    padding: 0.1rem 0.4rem;
    border-radius: 0.2rem;
  }
  .code-block {
    position: relative;
  }
  .copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: var(--sl-color-gray-5);
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 0.25rem;
    padding: 0.2rem 0.4rem;
    cursor: pointer;
    font-size: 0.8rem;
    z-index: 1;
  }
  .copy-btn:hover {
    background: var(--sl-color-gray-4);
  }
  pre {
    margin: 0;
    padding: 1rem;
    overflow-x: auto;
  }
</style>
