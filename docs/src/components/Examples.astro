---
/**
 * Examples — renders code examples with language tabs and copy buttons.
 */
import { Code } from '@astrojs/starlight/components';
import DocContent from './DocContent.astro';
import { dedent } from '../utils/packages';

const { examples = [], allTypes = [], packageName = '' } = Astro.props;

if (!examples || examples.length === 0) return;

const langLabels: Record<string, string> = {
  csharp: 'C#',
  typescript: 'TypeScript',
  python: 'Python',
  java: 'Java',
  go: 'Go',
  rust: 'Rust',
  json: 'JSON',
  xml: 'XML',
  bash: 'Bash',
};

/* Only show language titles when examples span multiple languages. */
const languages = new Set(examples.map((ex: any) => ex.language ?? 'csharp'));
const showTitle = languages.size > 1;
---

<div class="ex-container not-content">
  {examples.map((ex: any) => {
    const lang = ex.language ?? 'csharp';
    return (
      <div class="ex-item">
        {ex.description && (
          <div class="ex-desc">
            <DocContent content={ex.description} allTypes={allTypes} packageName={packageName} tag="p" />
          </div>
        )}
        {ex.region && <span class="ex-region">#{ex.region}</span>}
        <Code code={dedent(ex.code)} lang={lang} {...(showTitle ? { title: langLabels[lang] ?? lang } : {})} />
      </div>
    );
  })}
</div>

<style>
  .ex-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 1rem 0;
  }
  .ex-item {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .ex-desc {
    font-size: 0.85rem;
    color: var(--sl-color-gray-2);
    margin: 0;
  }
  .ex-desc :global(p) { margin: 0; }
  .ex-region {
    font-size: 0.75rem;
    background: var(--sl-color-gray-5);
    padding: 0.1rem 0.4rem;
    border-radius: 0.2rem;
    align-self: flex-start;
  }
</style>
