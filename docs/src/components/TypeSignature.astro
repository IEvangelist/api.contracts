---
/**
 * TypeSignature — renders a type's C# declaration.
 *
 * Clean code block with generic parameter constraints and
 * base/interface listing. No heavy card wrapper.
 */
import { Code } from '@astrojs/starlight/components';
import { typeHref, shortTypeName } from '../utils/packages';

interface Props {
  type: any;
  allTypes?: any[];
  packageName?: string;
}

const { type, allTypes = [], packageName = '' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const modifiers = [
  type.accessibility,
  type.isStatic ? 'static' : null,
  type.isAbstract ? 'abstract' : null,
  type.isSealed ? 'sealed' : null,
].filter(Boolean).join(' ');

let signature = `${modifiers} ${type.kind} ${type.name}`;

if (type.isGeneric && type.genericParameters?.length) {
  signature += `<${type.genericParameters.map((g: any) => g.name).join(', ')}>`;
}

const bases: string[] = [];
if (type.baseType) bases.push(type.baseType);
if (type.interfaces?.length) bases.push(...type.interfaces);

if (bases.length) {
  signature += `\n    : ${bases.join(',\n      ')}`;
}

/* Build constraint lines for generic parameters. */
const constraints = (type.genericParameters ?? [])
  .filter((gp: any) => gp.constraints?.length > 0)
  .map((gp: any) => `    where ${gp.name} : ${gp.constraints.join(', ')}`);

if (constraints.length) {
  signature += '\n' + constraints.join('\n');
}
---

<div class="ts not-content">
  <div class="ts-code">
    <Code code={signature} lang="csharp" showLineNumbers={false} />
  </div>

  {type.genericParameters?.length > 0 && (
    <div class="ts-generics">
      {type.genericParameters.map((gp: any) => (
        <div class="ts-gp">
          <code class="ts-gp-name">{gp.name}</code>
          {gp.constraints?.length > 0 && (
            <span class="ts-gp-constraint">
              {gp.constraints.join(', ')}
            </span>
          )}
        </div>
      ))}
    </div>
  )}

  {bases.length > 0 && (
    <div class="ts-bases">
      {bases.map((b: string) => {
        const target = allTypes.find((t: any) => t.fullName === b);
        const shortName = shortTypeName(b);
        return target ? (
          <a href={typeHref(base, packageName, target.name)} class="ts-base-link">{shortName}</a>
        ) : (
          <span class="ts-base-ext">{shortName}</span>
        );
      })}
    </div>
  )}
</div>

<style>
  .ts {
    margin-bottom: 1.5rem;
  }
  .ts-code {
    margin: 0;
    border-radius: 0.5rem;
    overflow: hidden;
    border: 1px solid var(--sl-color-gray-5);
  }
  .ts-code :global(.astro-code) {
    margin: 0;
    padding: 1rem 1.25rem;
    border-radius: 0.5rem;
    font-size: 0.88rem;
    line-height: 1.55;
  }
  .ts-code :global(pre) {
    margin: 0;
    border-radius: 0.5rem;
  }
  .ts-code :global(figure.frame) {
    margin: 0;
    border: none;
    border-radius: 0.5rem;
  }
  .ts-generics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }
  .ts-gp {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    font-size: 0.85rem;
    padding: 0.3rem 0.6rem;
    background: var(--sl-color-gray-7);
    border-radius: 0.3rem;
    border: 1px solid var(--sl-color-gray-6);
  }
  .ts-gp-name {
    font-weight: 600;
    color: var(--sl-color-accent);
    background: none;
    padding: 0;
    font-size: inherit;
  }
  .ts-gp-constraint {
    color: var(--sl-color-gray-3);
    font-size: 0.8rem;
  }
  .ts-bases {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.5rem;
  }
  .ts-base-link {
    display: inline-block;
    font-size: 0.82rem;
    padding: 0.2rem 0.55rem;
    border-radius: 0.25rem;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-accent);
    text-decoration: none;
    font-weight: 500;
    border: 1px solid var(--sl-color-gray-5);
    transition: border-color 0.1s;
  }
  .ts-base-link:hover {
    border-color: var(--sl-color-accent);
  }
  .ts-base-ext {
    display: inline-block;
    font-size: 0.82rem;
    padding: 0.2rem 0.55rem;
    border-radius: 0.25rem;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-2);
    border: 1px solid var(--sl-color-gray-5);
  }
</style>
