---
/**
 * /reference/[package]/[type] — Individual type detail page.
 *
 * Modern, flat layout optimized for API reference consumption.
 * No collapsible sections — everything is scannable and accessible.
 */
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { getCollection } from 'astro:content';
import TypeSignature from '../../../components/TypeSignature.astro';
import MemberList  from '../../../components/MemberList.astro';
import InheritanceDiagram from '../../../components/InheritanceDiagram.astro';
import EnumTable from '../../../components/EnumTable.astro';
import Examples  from '../../../components/Examples.astro';
import DocContent from '../../../components/DocContent.astro';
import AnchorHeading from '../../../components/AnchorHeading.astro';
import {
  slugify,
  typeHref,
  resolveTypeLink,
  parseSeeAlso,
  shortTypeName,
  memberKindLabels,
  memberKindOrder,
  groupMembersByKind,
} from '../../../utils/packages';

export async function getStaticPaths() {
  const packages = await getCollection('packages');
  const paths: any[] = [];
  for (const pkg of packages) {
    for (const t of pkg.data.types) {
      paths.push({
        params: {
          package: pkg.data.package.name,
          type: slugify(t.name),
        },
        props: {
          pkg: pkg.data,
          type: t,
          allTypes: pkg.data.types,
        },
      });
    }
  }
  return paths;
}

const { pkg, type, allTypes } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

/** Flatten doc nodes to a plain-text string (for meta description). */
function flattenToText(nodes: any): string {
  if (!nodes) return '';
  if (typeof nodes === 'string') return nodes;
  if (!Array.isArray(nodes)) return '';
  return nodes.map((n: any) => {
    if (typeof n === 'string') return n;
    if (n.kind === 'text' || n.kind === 'code' || n.kind === 'codeblock') return n.text ?? '';
    if (n.kind === 'langword') return n.value ?? '';
    if (n.kind === 'cref') return shortTypeName(n.value ?? '');
    if (n.kind === 'href') return n.text ?? n.value ?? '';
    if (n.kind === 'paramref' || n.kind === 'typeparamref') return n.value ?? '';
    if (n.kind === 'para' && n.children) return flattenToText(n.children);
    return '';
  }).join('');
}

const isEnum     = type.kind === 'enum';
const hasMembers = type.members?.length > 0;
const hasEnumMembers = type.enumMembers?.length > 0;
const hasBases   = !!type.baseType || type.interfaces?.length > 0;
const hasRemarks = type.docs?.remarks?.length > 0;
const hasValue   = type.docs?.value?.length > 0;
const hasTypeParams = type.docs?.typeParameters && Object.keys(type.docs.typeParameters).length > 0;
const hasPermissions = type.docs?.permissions?.length > 0;
const hasSeeAlso = type.docs?.seeAlso?.length > 0;
const hasExamples = type.docs?.examples?.length > 0;
const hasFlags = type.attributes?.some((a: any) => a.name === 'FlagsAttribute');

const summaryText = flattenToText(type.docs?.summary) || `${type.kind} ${type.name}`;

/* Collect modifier badges for the hero. */
const modifierBadges: string[] = [];
if (type.isAbstract) modifierBadges.push('abstract');
if (type.isStatic) modifierBadges.push('static');
if (type.isSealed) modifierBadges.push('sealed');
if (type.accessibility) modifierBadges.push(type.accessibility);

/* Build heading list for the right-side TOC. */
const headings: { depth: 2 | 3; slug: string; text: string }[] = [];
headings.push({ depth: 2, slug: 'definition', text: 'Definition' });
if (hasTypeParams) headings.push({ depth: 2, slug: 'type-parameters', text: 'Type Parameters' });
if (hasBases) headings.push({ depth: 2, slug: 'inheritance', text: 'Inheritance' });
if (hasRemarks) headings.push({ depth: 2, slug: 'remarks', text: 'Remarks' });
if (hasValue) headings.push({ depth: 2, slug: 'value', text: 'Value' });
if (hasEnumMembers) headings.push({ depth: 2, slug: 'enum-members', text: 'Enum Members' });
if (hasMembers) {
  const groups = groupMembersByKind(type.members);
  for (const kind of memberKindOrder) {
    if (groups.has(kind)) {
      headings.push({ depth: 2, slug: `members-${kind}`, text: memberKindLabels[kind] });
    }
  }
}
if (hasExamples) headings.push({ depth: 2, slug: 'examples', text: 'Examples' });
if (hasPermissions) headings.push({ depth: 2, slug: 'permissions', text: 'Permissions' });
if (hasSeeAlso) headings.push({ depth: 2, slug: 'see-also', text: 'See Also' });

/* Resolve seeAlso references. */
const seeAlsoLinks = (type.docs?.seeAlso ?? []).map((ref: string) => {
  if (ref.startsWith('http://') || ref.startsWith('https://')) {
    return { label: ref, href: ref, external: true, prefix: '' };
  }
  const { prefix, fullName, simpleName } = parseSeeAlso(ref);

  // For member references (P:, M:, F:, E:), try to resolve the owning type
  // e.g. P:SampleApi.Customer.PreferredContact → type=Customer, member=PreferredContact
  const isMemberRef = ['P', 'M', 'F', 'E'].includes(prefix);

  // Direct type match
  let target = allTypes.find((t: any) => t.fullName === fullName);
  if (!target && /`\d+$/.test(fullName)) {
    const baseName = fullName.replace(/`\d+$/, '');
    target = allTypes.find((t: any) =>
      t.fullName === baseName || t.fullName.startsWith(baseName + '<')
    );
  }

  // Member ref: find owning type by stripping the last segment
  let memberAnchor = '';
  if (!target && isMemberRef) {
    const lastDot = fullName.lastIndexOf('.');
    if (lastDot > 0) {
      const ownerFullName = fullName.slice(0, lastDot);
      const memberName = fullName.slice(lastDot + 1);
      target = allTypes.find((t: any) => t.fullName === ownerFullName);
      if (target) {
        memberAnchor = '#' + memberName.toLowerCase().replace(/[^a-z0-9]/g, '-');
      }
    }
  }

  const label = target
    ? (isMemberRef && memberAnchor ? shortTypeName(fullName) : target.name)
    : simpleName.replace(/`\d+$/, '');
  return {
    label,
    href: target ? typeHref(base, pkg.package.name, target.name) + memberAnchor : null,
    external: false,
    prefix,
  };
});

const displayName = type.name + (type.isGeneric && type.genericParameters?.length
  ? `<${type.genericParameters.map((g: any) => g.name).join(', ')}>`
  : '');

/* Kind display labels. */
const kindLabel: Record<string, string> = {
  class: 'Class',
  struct: 'Struct',
  interface: 'Interface',
  enum: 'Enum',
  delegate: 'Delegate',
  record: 'Record',
  'record struct': 'Record Struct',
};

/* Inheritance chain as a flat breadcrumb. */
const inheritChain: { name: string; href: string | null }[] = [];
if (type.baseType && type.baseType !== 'System.Object') {
  const baseTarget = allTypes.find((t: any) => t.fullName === type.baseType);
  inheritChain.push({
    name: shortTypeName(type.baseType),
    href: baseTarget ? typeHref(base, pkg.package.name, baseTarget.name) : null,
  });
}
inheritChain.push({ name: displayName, href: null });
---

<StarlightPage
  frontmatter={{
    title: displayName,
    description: summaryText,
  }}
  headings={headings}
>
  {/* ---- Breadcrumb ---- */}
  <nav class="type-breadcrumb not-content">
    <a href={`${base}/reference/`}>API Reference</a>
    <span class="sep">/</span>
    <a href={`${base}/reference/${pkg.package.name}/`}>{pkg.package.name}</a>
    <span class="sep">/</span>
    <span class="current">{type.name}</span>
  </nav>

  {/* ---- Hero ---- */}
  <div class="type-hero not-content">
    <div class="hero-header">
      <span class={`kind-pill kind-${type.kind.replace(/\s+/g, '-')}`}>{kindLabel[type.kind] ?? type.kind}</span>
      {modifierBadges.map(b => <span class="mod-pill">{b}</span>)}
    </div>
    {type.docs?.summary && (
      <div class="hero-summary">
        <DocContent content={type.docs.summary} allTypes={allTypes} packageName={pkg.package.name} />
      </div>
    )}
    <div class="hero-meta">
      <div class="meta-pair">
        <span class="meta-label">Namespace</span>
        <code class="meta-value">{type.namespace}</code>
      </div>
      <div class="meta-pair">
        <span class="meta-label">Assembly</span>
        <code class="meta-value">{pkg.package.name}</code>
      </div>
      <div class="meta-pair">
        <span class="meta-label">Package</span>
        <code class="meta-value">v{pkg.package.version}</code>
      </div>
    </div>
  </div>

  {/* ---- Definition (signature) ---- */}
  <AnchorHeading id="definition" text="Definition" />
  <TypeSignature type={type} allTypes={allTypes} packageName={pkg.package.name} />

  {/* ---- Type Parameters ---- */}
  {hasTypeParams && (
    <>
      <AnchorHeading id="type-parameters" text="Type Parameters" />
      <div class="tp-grid not-content">
        {Object.entries(type.docs.typeParameters).map(([name, desc]: [string, any]) => (
          <div class="tp-item">
            <code class="tp-name">{name}</code>
            <div class="tp-desc"><DocContent content={desc} allTypes={allTypes} packageName={pkg.package.name} /></div>
          </div>
        ))}
      </div>
    </>
  )}

  {/* ---- Inheritance ---- */}
  {hasBases && (
    <>
      <AnchorHeading id="inheritance" text="Inheritance" />
      {inheritChain.length > 1 && (
        <div class="inherit-chain not-content">
          {inheritChain.map((item, i) => (
            <>
              {i > 0 && <span class="chain-arrow">→</span>}
              {item.href ? (
                <a href={item.href} class="chain-link">{item.name}</a>
              ) : (
                <span class="chain-current">{item.name}</span>
              )}
            </>
          ))}
        </div>
      )}
      {type.interfaces?.length > 0 && (
        <div class="implements-list not-content">
          <span class="meta-label">Implements</span>
          <div class="impl-pills">
            {type.interfaces.map((iface: string) => {
              const ifaceTarget = allTypes.find((t: any) => t.fullName === iface);
              const ifaceShort = shortTypeName(iface);
              return ifaceTarget ? (
                <a href={typeHref(base, pkg.package.name, ifaceTarget.name)} class="impl-pill">{ifaceShort}</a>
              ) : (
                <span class="impl-pill ext">{ifaceShort}</span>
              );
            })}
          </div>
        </div>
      )}
      <InheritanceDiagram type={type} allTypes={allTypes} />
    </>
  )}

  {/* ---- Remarks ---- */}
  {hasRemarks && (
    <>
      <AnchorHeading id="remarks" text="Remarks" />
      <div class="remarks-block">
        <DocContent content={type.docs.remarks} allTypes={allTypes} packageName={pkg.package.name} tag="div" />
      </div>
    </>
  )}

  {/* ---- Value ---- */}
  {hasValue && (
    <>
      <AnchorHeading id="value" text="Value" />
      <div class="prose-block">
        <DocContent content={type.docs.value} allTypes={allTypes} packageName={pkg.package.name} />
      </div>
    </>
  )}

  {/* ---- Enum members ---- */}
  {hasEnumMembers && (
    <>
      <AnchorHeading id="enum-members" text="Enum Members" />
      <EnumTable enumMembers={type.enumMembers} hasFlags={hasFlags} />
    </>
  )}

  {/* ---- Members — each kind gets its own top-level section ---- */}
  {hasMembers && (
    <MemberList
      members={type.members}
      allTypes={allTypes}
      packageName={pkg.package.name}
    />
  )}

  {/* ---- Examples ---- */}
  {hasExamples && (
    <>
      <AnchorHeading id="examples" text="Examples" />
      <Examples examples={type.docs.examples} allTypes={allTypes} packageName={pkg.package.name} />
    </>
  )}

  {/* ---- Permissions ---- */}
  {hasPermissions && (
    <>
      <AnchorHeading id="permissions" text="Permissions" />
      <div class="permissions-grid not-content">
        {type.docs.permissions.map((perm: any) => (
          <div class="perm-item">
            <code class="perm-type">{perm.type}</code>
            <div class="perm-desc"><DocContent content={perm.description} allTypes={allTypes} packageName={pkg.package.name} /></div>
          </div>
        ))}
      </div>
    </>
  )}

  {/* ---- See Also ---- */}
  {hasSeeAlso && (
    <>
      <AnchorHeading id="see-also" text="See Also" />
      <div class="see-also-grid not-content">
        {seeAlsoLinks.map((link: any) => (
          link.href ? (
            <a href={link.href} class="sa-link" {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
              {link.label}
              {link.external && <span class="ext-icon">↗</span>}
            </a>
          ) : (
            <span class="sa-unresolved"><code>{link.label}</code></span>
          )
        ))}
      </div>
    </>
  )}
</StarlightPage>

{/* ---- Mermaid initializer (only when diagram is present) ---- */}
{hasBases && (
  <script type="module">
    import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';

    function getTheme() {
      const isDark = document.documentElement.dataset.theme === 'dark' ||
        document.documentElement.classList.contains('dark');
      return isDark ? 'dark' : 'default';
    }

    mermaid.initialize({
      startOnLoad: true,
      theme: getTheme(),
      securityLevel: 'loose',
    });
  </script>
)}

<style>
  /* ---- Breadcrumb ---- */
  .type-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    margin-bottom: 1.25rem;
    color: var(--sl-color-gray-3);
  }
  .type-breadcrumb a {
    color: var(--sl-color-gray-3);
    text-decoration: none;
  }
  .type-breadcrumb a:hover {
    color: var(--sl-color-accent);
    text-decoration: underline;
  }
  .type-breadcrumb .sep { opacity: 0.4; }
  .type-breadcrumb .current {
    color: var(--sl-color-text);
    font-weight: 600;
  }

  /* ---- Hero ---- */
  .type-hero {
    background: var(--sl-color-gray-7);
    border: 1px solid var(--sl-color-gray-6);
    border-radius: 0.75rem;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }
  .hero-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }
  .kind-pill {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.2rem 0.65rem;
    border-radius: 2rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    background: var(--sl-color-accent);
    color: var(--sl-color-white);
  }
  .kind-interface { background: #8b5cf6; }
  .kind-enum { background: #f59e0b; color: #1a1a1a; }
  .kind-struct, .kind-record-struct { background: #10b981; }
  .kind-delegate { background: #ec4899; }
  .kind-record { background: #06b6d4; }
  .mod-pill {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.15rem 0.5rem;
    border-radius: 2rem;
    background: var(--sl-color-gray-5);
    color: var(--sl-color-gray-1);
    letter-spacing: 0.02em;
  }
  .hero-summary {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--sl-color-gray-1);
    margin-bottom: 1rem;
  }
  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--sl-color-gray-6);
  }
  .meta-pair {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .meta-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--sl-color-gray-3);
  }
  .meta-value {
    font-size: 0.85rem;
    color: var(--sl-color-text);
    background: none;
    padding: 0;
  }

  /* ---- Inheritance ---- */
  .inherit-chain {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
  }
  .chain-arrow {
    color: var(--sl-color-gray-4);
    font-size: 0.8rem;
  }
  .chain-link {
    color: var(--sl-color-accent);
    text-decoration: none;
    font-weight: 500;
  }
  .chain-link:hover { text-decoration: underline; }
  .chain-current {
    font-weight: 600;
    color: var(--sl-color-text);
  }
  .implements-list {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .impl-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .impl-pill {
    display: inline-block;
    font-size: 0.8rem;
    padding: 0.2rem 0.6rem;
    border-radius: 0.3rem;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-accent);
    text-decoration: none;
    font-weight: 500;
    border: 1px solid var(--sl-color-gray-5);
    transition: border-color 0.1s;
  }
  .impl-pill:hover {
    border-color: var(--sl-color-accent);
    text-decoration: none;
  }
  .impl-pill.ext {
    color: var(--sl-color-gray-2);
  }

  /* ---- Remarks ---- */
  .remarks-block {
    border-left: 3px solid var(--sl-color-accent);
    padding: 0.75rem 1.25rem;
    margin-bottom: 1.5rem;
    background: var(--sl-color-gray-7);
    border-radius: 0 0.4rem 0.4rem 0;
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--sl-color-gray-2);
  }
  .remarks-block :global(p) { margin: 0.25rem 0; }
  .prose-block {
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
    color: var(--sl-color-gray-2);
  }

  /* ---- Type Parameters ---- */
  .tp-grid {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .tp-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    align-items: baseline;
    padding: 0.5rem 0.75rem;
    background: var(--sl-color-gray-7);
    border-radius: 0.35rem;
  }
  .tp-name {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--sl-color-accent);
    background: none;
    padding: 0;
  }
  .tp-desc {
    font-size: 0.9rem;
    color: var(--sl-color-gray-2);
    line-height: 1.5;
  }

  /* ---- Permissions ---- */
  .permissions-grid {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .perm-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    align-items: baseline;
    padding: 0.5rem 0.75rem;
    background: var(--sl-color-gray-7);
    border-radius: 0.35rem;
  }
  .perm-type {
    font-weight: 600;
    font-size: 0.85rem;
  }
  .perm-desc {
    font-size: 0.9rem;
    color: var(--sl-color-gray-2);
  }

  /* ---- See Also ---- */
  .see-also-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .sa-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.35rem 0.75rem;
    border-radius: 0.35rem;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-accent);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    border: 1px solid transparent;
    transition: border-color 0.1s;
  }
  .sa-link:hover {
    border-color: var(--sl-color-accent);
  }
  .ext-icon { font-size: 0.75rem; }
  .sa-unresolved {
    padding: 0.35rem 0.75rem;
    border-radius: 0.35rem;
    background: var(--sl-color-gray-6);
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
  }
</style>
